# 表格页「保存」+「同步到 Git」所需环境变量（Vercel Settings → Environment Variables）
# 不要将真实值提交到 Git！

# 保存密码（点「保存」或「同步到 Git」时在网页输入）
TABLE_SAVE_SECRET=自定义密码

# Upstash Redis：Vercel 里 Integrations → 添加 Upstash Redis 后会自动注入下面两个（也可手动填）
KV_REST_API_URL=    # 或 UPSTASH_REDIS_REST_URL
KV_REST_API_TOKEN=  # 或 UPSTASH_REDIS_REST_TOKEN

# 同步到 Git 时用（可选：不配则只能「保存」到 KV，不能「同步到 Git」）
GITHUB_TOKEN=GitHub Personal Access Token，需勾选 repo
GITHUB_REPO=owner/repo，例如 Chensiqi17/miracle-plus-gallery
# GITHUB_BRANCH=main  可选
